#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

"${SCRIPT_DIR}/run-with-elixir" mix local.hex --force
"${SCRIPT_DIR}/run-with-elixir" mix local.rebar --force
"${SCRIPT_DIR}/run-with-elixir" mix deps.get
"${SCRIPT_DIR}/run-with-elixir" mix ecto.create
"${SCRIPT_DIR}/run-with-elixir" mix ecto.migrate
